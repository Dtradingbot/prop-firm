# ─── DATABASE (MySQL — from Hostinger hPanel) ─────────────────────────────────
# Format: mysql://USERNAME:PASSWORD@HOST:3306/DATABASE_NAME
DATABASE_URL="mysql://u123456789_propfirm:YourPassword@127.0.0.1:3306/u123456789_propfirm"

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="replace-this-with-a-64-character-random-string"

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=3001
NODE_ENV="production"
FRONTEND_URL="https://couponen.com"

# ─── EMAIL (optional) ─────────────────────────────────────────────────────────
SMTP_HOST="smtp.hostinger.com"
SMTP_PORT=587
SMTP_USER="noreply@couponen.com"
SMTP_PASS="your-email-password"
